# Copy to .env for local dev. For Netlify, set these in Site settings → Environment variables.
# Do NOT commit .env or any file containing the private key.

# Google Sheet ID (from the sheet URL: .../d/<THIS_ID>/edit)
GOOGLE_SHEET_ID=
# Or use the same name you had:
# SHEETS_ID=

# Service account (from your JSON key file)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# Private key: paste the full "private_key" value from the JSON (with \n for newlines, or real newlines)
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
